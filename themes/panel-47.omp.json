{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "console_title_template": "PANEL-47 в–Ә {{ .Folder }}",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#FF9900",
          "style": "plain",
          "template": "в•ӯв”Җ",
          "type": "text"
        },
        {
          "background": "#FF9900",
          "foreground": "#000000",
          "leading_diamond": "оӮ¶",
          "style": "diamond",
          "template": "{{ if .WSL }}WSL {{ end }}{{ .Icon }}",
          "trailing_diamond": "оӮҙв”Җ",
          "type": "os"
        },
        {
          "background": "#FF9900",
          "foreground": "#000000",
          "leading_diamond": "оӮ¶",
          "style": "diamond",
          "template": "п’ү {{ upper .Name }} {{ .Version }}",
          "trailing_diamond": "оӮҙв”Җ",
          "type": "shell"
        },
        {
          "background": "#FFCC66",
          "foreground": "#000000",
          "leading_diamond": "оӮ¶",
          "style": "diamond",
          "template": "пҖҮ {{ .UserName }}@{{ .HostName }}{{ if .SSHSession }} п — SSH{{ end }}",
          "trailing_diamond": "оӮҙв”Җ",
          "type": "session"
        },
        {
          "background": "#FFCC99",
          "foreground": "#000000",
          "leading_diamond": "оӮ¶",
          "options": {
            "style": "full",
            "home_icon": "пҖ• ~",
            "folder_separator_icon": " оӮұ "
          },
          "style": "diamond",
          "template": "о—ҝ {{ .Path }}",
          "trailing_diamond": "оӮҙв”Җ",
          "type": "path"
        },
        {
          "background": "#CC99CC",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#CC6666{{ end }}",
            "{{ if or (gt .Ahead 0) (gt .Behind 0) }}#9999CC{{ end }}"
          ],
          "foreground": "#000000",
          "leading_diamond": "оӮ¶",
          "options": {
            "fetch_status": true,
            "fetch_stash_count": true,
            "fetch_upstream_icon": true
          },
          "style": "diamond",
          "template": "{{ .UpstreamIcon }}{{ .HEAD }}{{ if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} пҒ„ {{ .Working.String }}{{ end }}{{ if .Staging.Changed }} пҒҶ {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} пҖң {{ .StashCount }}{{ end }}",
          "trailing_diamond": "оӮҙв”Җ",
          "type": "git"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "filler": "<#FF9900>в”Җ</>",
      "segments": [
        {
          "background": "#CC6699",
          "foreground": "#000000",
          "leading_diamond": "оӮ¶",
          "style": "diamond",
          "template": "{{ if ne .Status \"stopped\" }}пҶј {{ .Artist }} вҖ” {{ .Track }}{{ end }}",
          "trailing_diamond": "оӮҙв”Җ",
          "type": "spotify"
        },
        {
          "background": "#9999CC",
          "foreground": "#000000",
          "leading_diamond": "оӮ¶",
          "style": "diamond",
          "template": "{{ if eq .Type \"wifi\" }}пҮ« WIFI{{ else if eq .Type \"ethernet\" }}пҮҰ LAN{{ end }}",
          "trailing_diamond": "оӮҙв”Җ",
          "type": "connection"
        },
        {
          "background": "#FF9966",
          "foreground": "#000000",
          "leading_diamond": "оӮ¶",
          "style": "diamond",
          "template": "пӢӣ MEM {{ printf \"%.0f\" .PhysicalPercentUsed }}%",
          "trailing_diamond": "оӮҙв”Җ",
          "type": "sysinfo"
        },
        {
          "background": "#FFCC66",
          "background_templates": [
            "{{ if eq \"Discharging\" .State.String }}#CC6666{{ end }}",
            "{{ if eq \"Full\" .State.String }}#99CCFF{{ end }}"
          ],
          "foreground": "#000000",
          "leading_diamond": "оӮ¶",
          "options": {
            "charged_icon": "пүҖ ",
            "charging_icon": "пғ§ ",
            "discharging_icon": "пүӮ "
          },
          "style": "diamond",
          "template": "{{ if not .Error }}{{ .Icon }}{{ .Percentage }}%{{ end }}",
          "trailing_diamond": "оӮҙв”Җ",
          "type": "battery"
        },
        {
          "background": "#99CCFF",
          "foreground": "#000000",
          "leading_diamond": "оӮ¶",
          "options": {
            "time_format": "15:04:05"
          },
          "style": "diamond",
          "template": "пҖ… SD {{ printf \"%d.%03d\" .CurrentDate.Year .CurrentDate.YearDay }} пҖ— {{ .CurrentDate | date .Format }}",
          "trailing_diamond": "оӮҙ",
          "type": "time"
        },
        {
          "foreground": "#FF9900",
          "style": "plain",
          "template": "в”Җв•®",
          "type": "text"
        }
